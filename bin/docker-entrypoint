#!/bin/bash -e

# If running the rails server then create or migrate the database, and load
# seeds. db:seed is idempotent (find_or_initialize_by), so it's safe on every
# boot and ensures reference data (competition templates) is always present —
# db:prepare alone only seeds when it first creates the database.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  ./bin/rails db:seed
fi

exec "${@}"
