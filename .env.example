# Copy to `.env` (git-ignored) and fill in real values for local development.
# NEVER put real secrets in this example file — it is committed.

# Database (the local dev `sweep` MySQL/MariaDB user).
DB_USERNAME=sweep
DB_PASSWORD=change-me
DB_HOST=127.0.0.1

# Comma-separated list of allowed SPA origins for CORS.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Production-only (set as real environment variables, not in a committed file) ---
# DB_NAME=sweep_production
# RAILS_MASTER_KEY=...                 # decrypts config/credentials.yml.enc (jwt_secret, etc.)
# APP_HOSTS=sweep.je,api.sweep.je      # Host-header allowlist (DNS-rebinding protection)
# TRUSTED_PROXIES=10.0.0.0/8           # your load balancer's IP/CIDR (correct client IP for rate limits)
